{
  "openapi": "3.1.0",
  "info": {
    "title": "SmartBuy Backend API",
    "version": "0.2.0",
    "description": "HTTP contract for the SmartBuy BH operational backend.",
    "x-contract-id": "SBH-OPENAPI-002"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Service availability."
    },
    {
      "name": "Identity",
      "description": "Authenticated operational identity."
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Read service health",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "The service is operational.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              },
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/session": {
      "get": {
        "operationId": "getOperatorSession",
        "summary": "Read the authenticated operator session",
        "description": "Validates the bearer token and returns the active operator profile and authorized capabilities.",
        "tags": ["Identity"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "The operator session is authenticated and authorized.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              },
              "Vary": {
                "$ref": "#/components/headers/VaryAuthorization"
              },
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "The bearer token is absent, malformed, expired, or invalid.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              },
              "Vary": {
                "$ref": "#/components/headers/VaryAuthorization"
              },
              "WWW-Authenticate": {
                "$ref": "#/components/headers/BearerChallenge"
              },
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "The authenticated identity is not authorized as an active operator.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              },
              "Vary": {
                "$ref": "#/components/headers/VaryAuthorization"
              },
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "The identity dependency or its configuration is unavailable.",
            "headers": {
              "Cache-Control": {
                "$ref": "#/components/headers/NoStore"
              },
              "Vary": {
                "$ref": "#/components/headers/VaryAuthorization"
              },
              "X-Correlation-ID": {
                "$ref": "#/components/headers/CorrelationId"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AvailabilityErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase Auth access token."
      }
    },
    "headers": {
      "NoStore": {
        "description": "Prevents storage of health and session responses.",
        "schema": {
          "type": "string",
          "const": "no-store"
        }
      },
      "VaryAuthorization": {
        "description": "Marks the authorization header as a response variant.",
        "schema": {
          "type": "string",
          "const": "authorization"
        }
      },
      "CorrelationId": {
        "description": "Request correlation identifier.",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "BearerChallenge": {
        "description": "Bearer authentication challenge.",
        "schema": {
          "type": "string",
          "const": "Bearer realm=\"smartbuy-backend\""
        }
      }
    },
    "schemas": {
      "CorrelationMeta": {
        "type": "object",
        "additionalProperties": false,
        "required": ["correlationId"],
        "properties": {
          "correlationId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "HealthData": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "status", "checkedAt"],
        "properties": {
          "service": {
            "type": "string",
            "const": "smartbuy-backend"
          },
          "status": {
            "type": "string",
            "const": "ok"
          },
          "checkedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["data", "meta"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/HealthData"
          },
          "meta": {
            "$ref": "#/components/schemas/CorrelationMeta"
          }
        }
      },
      "OperatorSession": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capabilities", "displayName", "role", "userId"],
        "properties": {
          "capabilities": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]{0,63}:[a-z][a-z0-9_-]{0,63}$"
            }
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "role": {
            "type": "string",
            "const": "operator"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "SessionResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["data", "meta"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/OperatorSession"
          },
          "meta": {
            "$ref": "#/components/schemas/CorrelationMeta"
          }
        }
      },
      "AuthenticationError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "const": "AUTHENTICATION_REQUIRED"
          },
          "message": {
            "type": "string",
            "const": "Authentication is required."
          }
        }
      },
      "AccessError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "const": "ACCESS_DENIED"
          },
          "message": {
            "type": "string",
            "const": "Access is denied."
          }
        }
      },
      "AvailabilityError": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "const": "IDENTITY_SERVICE_UNAVAILABLE"
          },
          "message": {
            "type": "string",
            "const": "The identity service is temporarily unavailable."
          }
        }
      },
      "AuthenticationErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error", "meta"],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/AuthenticationError"
          },
          "meta": {
            "$ref": "#/components/schemas/CorrelationMeta"
          }
        }
      },
      "AccessErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error", "meta"],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/AccessError"
          },
          "meta": {
            "$ref": "#/components/schemas/CorrelationMeta"
          }
        }
      },
      "AvailabilityErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error", "meta"],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/AvailabilityError"
          },
          "meta": {
            "$ref": "#/components/schemas/CorrelationMeta"
          }
        }
      }
    }
  }
}
